{
  "name": "worktree-cli",
  "version": "0.2.0",
  "description": "Git worktree manager CLI — convert repos to bare, checkout worktrees, manage branches",
  "license": "MIT",
  "type": "module",
  "bin": {
    "wt": "./bin/wt.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fredericoo/worktree-cli"
  },
  "keywords": [
    "git",
    "worktree",
    "bare",
    "cli",
    "developer-tools",
    "bun"
  ],
  "files": [
    "bin",
    "src",
    "skills",
    "CLAUDE.md"
  ],
  "scripts": {
    "test": "bun test",
    "lint": "oxlint --type-aware src/",
    "lint:fix": "oxlint --type-aware --fix src/",
    "fmt": "oxfmt src/",
    "fmt:check": "oxfmt --check src/",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run typecheck && bun run lint && bun run test && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0"
  }
}
